import csv, json, time
from connections import API as api
from tqdm import tqdm

def get(uri):
	if api.connect(env):
		response = api.client.get(uri)
		code = response.status_code
		if code == 200:
			result = response.json()
			return result
		else:
			error = response.text
			error = json.loads(error)
			to_csv(uri, code, error)
			return

def post(uri, data):
    if api.connect(env):
        response = api.client.post(uri, json=data)
        code = response.status_code
        if code == 200:
            result = response.json()
            to_csv(uri, code, result)
            return result, True
        else:
            try:
                error = response.text
                error = json.loads(error)
                to_csv(uri, code, error)
            except json.JSONDecodeError:
                error = response.text
                to_csv(uri, code, error)
            return error, False

def csv_config(path):
	date_str = date_str = time.strftime("%y%m%d")
	updatefile = open(f'{path}/{date_str}_results.csv', 'a', encoding='utf8', newline='')
	writer = csv.DictWriter(updatefile, fieldnames=['uri', 'code', 'result'])
	writer.writeheader()
	return writer

def to_csv(uri, code, result):
	row_dict = {}
	row_dict['uri'] = uri
	row_dict['code'] = code
	row_dict['result'] = result
	writer.writerow(row_dict)	
      
def proccess_csv(file):
    values = {}
    with open(file, newline='', encoding='utf-8') as csvfile:
        reader = csv.reader(csvfile)
        headers = next(reader)
        for i, row in enumerate(reader, start=1):
            if row:
                values[i] = {
                    'uri': row[6],
                    'note': row[4],
                    'tc_indicator': row[1],
                    'c_indicator': row[2],
                    'gc_indicator': row[3]
                }
    return values

def create_tc(value):
    instance = {
        'indicator': value['tc_indicator'],
        'jsonmodel_type': 'top_container',
        'restricted': True,
        'type': 'box'
    }
    result, posted = post('/repositories/3/top_containers', instance)
    uri = result.get('uri') if posted else (
        result.get('error', {}).get('conflicting_record', [None])[0]
    )
    if uri:
        value['tc_uri'] = uri
    return value

def backup(uri, data):
	with open(f"{path}/backups/{uri.replace('/','_')}.json", 'w', encoding='utf8') as outfile:
	    json.dump(data, outfile, sort_keys=True, indent=4)

def update_ao(value):
    uri = value['uri']
    tc_uri = value['tc_uri']
    child_indicator = value.get('c_indicator')
    grandchild_indicator = value.get('gc_indicator')
    record = get(uri)
    backup(uri, record)

    if value['note']:
        for n in record['notes']:
            check_subnotes = n.get('subnotes')
            if check_subnotes:
                subnotes = n['subnotes'][0]
                if 'content' in subnotes:
                     contentnotes = subnotes['content']
                     if value['note'] == contentnotes:
                          n['type'] = 'scopecontent'
        
    instance_template = {
        "instance_type": "mixed_materials",
        "jsonmodel_type": "instance",
        "lock_version": 0,
        "sub_container": {
            "jsonmodel_type": "sub_container",
            "lock_version": 0,
            "top_container": {
                "ref": tc_uri
            }}}
    if child_indicator:
        instance_template["sub_container"]["indicator_2"] = child_indicator
        instance_template["sub_container"]["type_2"] = "folder"

    if grandchild_indicator:
        instance_template["sub_container"]["indicator_3"] = grandchild_indicator
        instance_template["sub_container"]["type_3"] = "item"
         
    if 'instances' in record:
         record['instances'].append(instance_template)
    else:
        record['instances'] = [instance_template]
    post(uri, record)

def main():
    global env, writer, path
    env = 'production'
    path = 'files/ycba_instances'
    writer = csv_config(path)
    file = f'{path}/20260310_ycba_instances.csv'
    values = proccess_csv(file)
    topcontainers = {}

    for i in tqdm(values, desc="Processing Records", unit="record"):
        value = values[i]
        tc_indicator = value['tc_indicator']

        if tc_indicator in topcontainers:
            value['tc_uri'] = topcontainers[tc_indicator]
        else:
            value = create_tc(value)
            topcontainers[tc_indicator] = value['tc_uri']

        update_ao(value)


if __name__ == "__main__":
    main()
